<% content_for :title, t("account_users.index.title") %>

<section class="space-y-6">
  <h1 class="text-2xl font-semibold"><%= t("account_users.index.title") %></h1>

  <% if @account_users.any? %>
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left text-gray-500 border-b">
          <th class="py-2"><%= User.human_attribute_name(:name) %></th>
          <th class="py-2"><%= User.human_attribute_name(:email_address) %></th>
          <th class="py-2"><%= t("account_users.index.role") %></th>
          <th class="py-2"><%= t("account_users.index.actions") %></th>
        </tr>
      </thead>
      <tbody>
        <% @account_users.each do |au| %>
          <tr class="border-b">
            <td class="py-2"><%= au.user.name %></td>
            <td class="py-2"><%= au.user.email_address %></td>
            <td class="py-2">
              <% if policy(au).update? %>
                <%= form_with model: au, url: account_user_path(au), method: :patch, class: "inline-flex gap-2 items-center" do |form| %>
                  <%= form.select :role, AccountUser::ROLES.map { |k, v| [ t("activerecord.attributes.account_user/roles.#{k}"), v ] }, {}, class: "border border-gray-300 rounded-md px-2 py-1 text-sm" %>
                  <%= form.submit t("account_users.index.promote"), class: "text-blue-600 hover:underline text-sm" %>
                <% end %>
              <% else %>
                <%= t("activerecord.attributes.account_user/roles.#{au.role}") %>
              <% end %>
            </td>
            <td class="py-2">
              <% if policy(au).destroy? %>
                <%= button_to t("account_users.index.remove"), account_user_path(au), method: :delete, class: "text-red-600 hover:underline bg-transparent border-0 p-0 cursor-pointer text-sm", form: { data: { turbo_confirm: nil } } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-gray-500 text-sm"><%= t("account_users.index.empty") %></p>
  <% end %>

  <% if policy(AccountUser.new(account: Current.account)).create? %>
    <fieldset class="border border-gray-200 rounded-md p-4">
      <legend class="text-sm font-medium text-gray-700 px-2"><%= t("account_users.index.invite_legend") %></legend>
      <%= form_with model: @new_account_user, url: account_users_path, class: "space-y-3" do |form| %>
        <div>
          <%= form.label :email_address, t("account_users.index.email_label"), class: "block text-sm text-gray-700" %>
          <%= form.email_field :email_address, required: true, class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-1 w-full" %>
        </div>
        <div>
          <%= form.label :role, t("account_users.index.role"), class: "block text-sm text-gray-700" %>
          <%= form.select :role, AccountUser::ROLES.map { |k, v| [ t("activerecord.attributes.account_user/roles.#{k}"), v ] }, {}, class: "border border-gray-300 rounded-md px-2 py-1 text-sm mt-1" %>
        </div>
        <%= form.submit t("account_users.index.invite_submit"), class: "rounded-md px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium cursor-pointer" %>
      <% end %>
    </fieldset>
  <% end %>
</section>
