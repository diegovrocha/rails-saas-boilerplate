<% content_for :title, t("app.name") %>

<% if authenticated? && Current.user %>
  <section class="space-y-3">
    <h1 class="text-2xl font-semibold"><%= t("home.greeting", name: Current.user.name) %></h1>
    <% if Current.account %>
      <p class="text-gray-700"><%= t("home.on_account", account: Current.account.name) %></p>
    <% end %>

    <% if Current.user.accounts.count > 1 %>
      <div>
        <h2 class="text-lg font-medium mt-4"><%= t("layout.switch_account") %></h2>
        <ul class="mt-2 space-y-1">
          <% Current.user.accounts.each do |account| %>
            <li>
              <%= button_to account.name, switch_account_path(account), class: "text-blue-600 hover:underline bg-transparent border-0 p-0 cursor-pointer" %>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </section>
<% else %>
  <section class="space-y-4 text-center py-12">
    <h1 class="text-3xl font-semibold"><%= t("home.welcome_guest") %></h1>
    <div class="flex justify-center gap-4">
      <%= link_to t("home.sign_in_link"), new_session_path, class: "rounded-md bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 font-medium" %>
      <%= link_to t("home.sign_up_link"), new_registration_path, class: "rounded-md border border-blue-600 text-blue-600 hover:bg-blue-50 px-4 py-2 font-medium" %>
    </div>
  </section>
<% end %>
