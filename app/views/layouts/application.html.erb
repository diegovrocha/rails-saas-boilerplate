<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || t("app.name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= t("app.name") %>">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>

  <body class="min-h-screen bg-gray-50 text-gray-900">
    <header class="bg-white border-b border-gray-200">
      <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
        <%= link_to t("app.name"), root_path, class: "font-semibold text-lg" %>

        <nav class="flex items-center gap-4 text-sm">
          <% if authenticated? && Current.user %>
            <% if Current.account %>
              <span class="text-gray-500">
                <%= t("layout.current_account") %>:
                <strong class="text-gray-800"><%= Current.account.name %></strong>
              </span>
              <%= link_to t("layout.members"), account_users_path, class: "text-blue-600 hover:underline" %>
              <% if Current.user.accounts.count > 1 %>
                <%= link_to t("layout.switch_account"), account_path(Current.account), class: "text-blue-600 hover:underline" %>
              <% end %>
            <% end %>
            <%= button_to t("layout.sign_out"), session_path, method: :delete, class: "text-sm text-gray-700 hover:underline bg-transparent border-0 p-0 cursor-pointer", form: { data: { turbo_confirm: nil } } %>
          <% else %>
            <%= link_to t("home.sign_in_link"), new_session_path, class: "text-blue-600 hover:underline" %>
            <%= link_to t("home.sign_up_link"), new_registration_path, class: "text-blue-600 hover:underline" %>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="max-w-5xl mx-auto px-4 py-8">
      <% if notice = flash[:notice] %>
        <div class="mb-4 rounded-lg bg-green-50 text-green-700 px-4 py-2 text-sm" id="notice"><%= notice %></div>
      <% end %>
      <% if alert = flash[:alert] %>
        <div class="mb-4 rounded-lg bg-red-50 text-red-700 px-4 py-2 text-sm" id="alert"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
