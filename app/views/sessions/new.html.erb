<% content_for :title, t("auth.sign_in.title") %>

<div class="mx-auto md:w-2/3 w-full">
  <h1 class="font-bold text-3xl mb-6"><%= t("auth.sign_in.title") %></h1>

  <%= form_with url: session_path, class: "space-y-4" do |form| %>
    <div>
      <%= form.label :email_address, User.human_attribute_name(:email_address), class: "block text-sm font-medium text-gray-700" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address], class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-1 w-full" %>
    </div>

    <div>
      <%= form.label :password, User.human_attribute_name(:password), class: "block text-sm font-medium text-gray-700" %>
      <%= form.password_field :password, required: true, autocomplete: "current-password", maxlength: 72, class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-1 w-full" %>
    </div>

    <div class="flex items-center justify-between">
      <%= form.submit t("auth.sign_in.submit"), class: "rounded-md px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer" %>
      <%= link_to t("auth.sign_in.forgot_password"), new_password_path, class: "text-sm text-gray-600 hover:underline" %>
    </div>
  <% end %>

  <p class="text-sm text-gray-600 mt-6">
    <%= t("auth.sign_in.no_account") %>
    <%= link_to t("auth.sign_in.sign_up"), new_registration_path, class: "text-blue-600 hover:underline" %>
  </p>
</div>
